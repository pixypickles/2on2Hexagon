      },
      () => {
        directions.forEach(direction => {
          touchDir[direction] = false;
        });
      }
    );
  });

document
  .querySelectorAll('[data-act]')
  .forEach(element => {
    const action =
      element.dataset.act;

    bindHoldButton(
      element,
      () => {
        touchAct[action] = true;
        pressAction(0, action);
      },
      () => {
        touchAct[action] = false;
        releaseAction(0, action);
      }
    );
  });

window.addEventListener(
  'keydown',
  event => {
    if (keys[event.code]) {
      return;
    }

    keys[event.code] = true;

    const playerOneActions = {
      KeyJ: 'A',
      KeyK: 'B',
      KeyL: 'C',
      Semicolon: 'D'
    };

    const playerTwoActions = {
      Digit1: 'A',
      Digit2: 'B',
      Digit3: 'C',
      Digit0: 'D'
    };

    if (playerOneActions[event.code]) {
      pressAction(
        0,
        playerOneActions[event.code]
      );
    }

    if (
      playerTwoActions[event.code] &&
      state?.mode === '2p'
    ) {
      pressAction(
        1,
        playerTwoActions[event.code]
      );
    }

    if (
      [
        'ArrowUp',
        'ArrowDown',
        'ArrowLeft',
        'ArrowRight',
        'Space'
      ].includes(event.code)
    ) {
      event.preventDefault();
    }
  }
);

window.addEventListener(
  'keyup',
  event => {
    keys[event.code] = false;

    const playerOneActions = {
      KeyJ: 'A',
      KeyK: 'B',
      KeyL: 'C',
      Semicolon: 'D'
    };

    const playerTwoActions = {
      Digit1: 'A',
      Digit2: 'B',
      Digit3: 'C',
      Digit0: 'D'
    };

    if (playerOneActions[event.code]) {
      releaseAction(
        0,
        playerOneActions[event.code]
      );
    }

    if (playerTwoActions[event.code]) {
      releaseAction(
        1,
        playerTwoActions[event.code]
      );
    }
  }
);

$('#startBtn').addEventListener(
  'click',
  newGame
);

$('#rematchBtn').addEventListener(
  'click',
  newGame
);

$('#menuBtn').addEventListener(
  'click',
  () => {
    result.classList.add('hidden');
    menu.classList.remove('hidden');
  }
);

$('#quitBtn').addEventListener(
  'click',
  () => {
    if (state) {
      state.running = false;
    }

    cancelAnimationFrame(raf);

    gameScreen.classList.add('hidden');
    menu.classList.remove('hidden');
  }
);